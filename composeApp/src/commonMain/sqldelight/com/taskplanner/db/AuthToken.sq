CREATE TABLE AuthTokenEntity (
    id INTEGER NOT NULL PRIMARY KEY DEFAULT 1,
    token TEXT NOT NULL,
    user_id TEXT NOT NULL,
    username TEXT NOT NULL
);

getToken:
SELECT * FROM AuthTokenEntity WHERE id = 1;

saveToken:
INSERT OR REPLACE INTO AuthTokenEntity (id, token, user_id, username) VALUES (1, ?, ?, ?);

clearToken:
DELETE FROM AuthTokenEntity;
